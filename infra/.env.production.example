# BuscaMedicos Production Environment Variables
# Copy this file to .env.production and fill in the values

# =============================================================================
# REQUIRED - MUST BE SET BEFORE DEPLOYMENT
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://buscamedicos:CHANGE_ME@postgres:5432/buscamedicos
POSTGRES_DB=buscamedicos
POSTGRES_USER=buscamedicos
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Security
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# =============================================================================
# OPTIONAL - CAN USE DEFAULTS
# =============================================================================

# Application Environment
APP_ENV=production
DEBUG=false

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://buscamedicos.example.com

# File Upload Limits
MAX_FILE_SIZE_MB=10

# Redis (optional - leave empty to disable)
REDIS_URL=

# App Version
APP_VERSION=1.0.0

# =============================================================================
# PRODUCTION NOTES
# =============================================================================
# 1. Generate SECRET_KEY: openssl rand -hex 32
# 2. Use strong PostgreSQL password: openssl rand -base64 24
# 3. TLS certificates are automatic via Caddy ACME
# 4. Never commit this file to version control
# 5. Database is NOT exposed outside the docker network
# 6. Redis is NOT exposed outside the docker network
