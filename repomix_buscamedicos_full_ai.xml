  ResourceAccessPolicy,
  ResourceAccessPolicyUpdatePayload,
  RetentionPolicy,
  RetentionPolicyCreatePayload,
} from '~/types/privacy'

definePageMeta({
  layout: 'admin',
  middleware: ['auth', 'role'],
  roles: ['super_admin', 'admin_validation', 'admin_support', 'admin_moderation', 'admin_privacy'],
})

