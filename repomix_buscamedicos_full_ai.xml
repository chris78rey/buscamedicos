            onPressed: () => Navigator.pop(context, true),
            child: const Text('Sí'),
          ),
        ],
      ),
    );

    if (accepted != true) return;

    try {
      final result = await ApiService.createAppointment(
        widget.token,
        professionalId: widget.professionalId,
