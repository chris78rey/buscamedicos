    </v-card>

    <v-card rounded="xl">
      <v-card-item>
        <v-card-title>Filtros</v-card-title>
      </v-card-item>

      <v-card-text>
        <v-row>
          <v-col cols="12" md="3">
            <v-select
              v-model="filters.status_filter"
              :items="['', ...statusOptions]"
              label="Status"
