    >
      No existen logs para los filtros seleccionados.
    </v-alert>

    <v-row v-else>
      <v-col
        v-for="log in logs"
        :key="log.id"
        cols="12"
        md="6"
      >
        <v-card class="h-100" rounded="xl">
          <v-card-item>
