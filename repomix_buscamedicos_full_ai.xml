      No existen incidentes para los filtros seleccionados.
    </v-alert>

    <v-row v-else>
      <v-col
        v-for="incident in incidents"
        :key="incident.id"
        cols="12"
        md="6"
      >
        <v-card class="h-100" rounded="xl">
          <v-card-item>
