## Auth Store (`stores/auth.ts`)

```ts
import { defineStore } from 'pinia'

type CurrentUser = {
  id: string
  email: string
  status?: string
  is_email_verified?: boolean
  role_codes?: RoleCode[]
  primary_role?: RoleCode | null
  actor_type?: 'admin' | 'patient' | 'professional' | 'unknown'
