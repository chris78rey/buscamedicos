<!-- TOAST -->
<div id="toast" class="toast" style="display:none"></div>

<script>
// Navigation
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const target = document.getElementById(id);
  if (target) {
    target.classList.add('active');
    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

function switchRole(role) {
  document.getElementById('prof-screens').style.display = role === 'professional' ? 'block' : 'none';
  document.getElementById('patient-screens').style.display = role === 'patient' ? 'block' : 'none';
  document.getElementById('admin-screens').style.display = role === 'admin' ? 'block' : 'none';
  
  if (role === 'professional') showScreen('prof-home');
  else if (role === 'patient') showScreen('patient-home');
  else if (role === 'admin') showScreen('admin-home');
}

function toggleSwitch(el) {
  el.classList.toggle('on');
}

function showToast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast' + (type ? ' ' + type : '');
  t.style.display = 'block';
  setTimeout(() => t.style.display = 'none', 3000);
}

function createTeleconsult() {
  showToast('✓ Sesión creada exitosamente', 'success');
  setTimeout(() => showScreen('prof-manage'), 1000);
}

function startTeleconsult() {
  document.getElementById('tc-status-badge').className = 'status-badge status-in-progress';
  document.getElementById('tc-status-badge').textContent = 'En Curso';
  document.getElementById('btn-start').disabled = true;
  document.getElementById('btn-end').disabled = false;
  document.getElementById('session-timer').style.display = 'block';
  startTimer();
  showToast('▶ Sesión iniciada - Paciente puede unirse', 'success');
}

function endTeleconsult() {
  document.getElementById('tc-status-badge').className = 'status-badge status-completed';
  document.getElementById('tc-status-badge').textContent = 'Completada';
  document.getElementById('btn-end').disabled = true;
  document.getElementById('session-timer').style.display = 'none';
  showToast('⏹ Sesión finalizada', 'success');
}

let timerInterval;
function startTimer() {
  let sec = 0;
  clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    sec++;
    document.getElementById('timer-display').textContent = 
      String(Math.floor(sec/60)).padStart(2,'0') + ':' + String(sec%60).padStart(2,'0');
  }, 1000);
}

function saveClinicalNote() {
  const v = parseInt(document.getElementById('note-version').textContent) + 1;
  document.getElementById('note-version').textContent = v;
  showToast('💾 Nota guardada - Nueva versión #' + v, 'success');
}

function signClinicalNote() {
  document.getElementById('note-status-badge').className = 'status-badge status-issued';
  document.getElementById('note-status-badge').textContent = 'Firmada';
  showToast('✍️ Nota firmada simple', 'success');
}

function createPrescription() {
  document.getElementById('rx-status-badge').className = 'status-badge status-draft';
  document.getElementById('rx-status-badge').textContent = 'Borrador';
  document.getElementById('btn-issue-rx').disabled = false;
  document.getElementById('btn-revoke-rx').disabled = true;
  showToast('💾 Receta creada como borrador', 'success');
}

function issuePrescription() {
  document.getElementById('rx-status-badge').className = 'status-badge status-issued';
  document.getElementById('rx-status-badge').textContent = 'Emitida';
  document.getElementById('btn-issue-rx').disabled = true;
  document.getElementById('btn-revoke-rx').disabled = false;
  showToast('✅ Receta emitida - Visible para paciente', 'success');
}

function revokePrescription() {
  document.getElementById('rx-status-badge').className = 'status-badge status-draft';
  document.getElementById('rx-status-badge').textContent = 'Revocada';
  document.getElementById('btn-revoke-rx').disabled = true;
  showToast('🚫 Receta revocada', 'error');
}

function saveCareInstructions() {
  showToast('💾 Indicaciones guardadas', 'success');
}

